{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LotusDate",
  "version": "0.1.1",
  "identifier": "network.proxidate.live",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "LotusDate",
        "width": 480,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {}
}
